{
  "expo": {
    "name": "Chekou Ganhou",
    "slug": "chekou-ganhou-2",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./Logo.png",
    "scheme": "frontend",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.chekouganhou.app",
      "adaptiveIcon": {
        "foregroundImage": "./Logo.png",
        "backgroundColor": "#059669"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./Logo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./Logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FFFFFF"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a5d769d5-56bd-4095-bd5d-dce76a63a52b"
      }
    }
  }
}
