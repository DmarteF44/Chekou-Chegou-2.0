{
  "expo": {
    "name": "Chekou Ganhou",
    "slug": "chekou-ganhou-2",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./Logo.png",
    "scheme": "frontend",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.chekouganhou.app",
      "adaptiveIcon": {
        "foregroundImage": "./Logo.png",
        "backgroundColor": "#059669"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./Logo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Permita que o Chekou Ganhou selecione imagens para o catálogo."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./Logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FFFFFF"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e3c8ba95-c730-4658-bc88-21681fc1b0c8"
      }
    },
    "owner": "dmartef44"
  }
}
